<div id="thread_{{ thread.id }}" style="border: black 1px solid" {% if sse %} hx-swap-oob="if-exists" {% endif %}>
	<p><a href="/thread/{{ thread.id }}">{{ thread.title }}</a>
		by <a href="/user/{{ author.id }}">{{ author.username }}</a> at {{ post.created_at }}</p>
	<p class="thread-body">{{ post.body }}</p>
</div>
